# Copy to .env and adjust. All variables are prefixed with TUTOR_.
TUTOR_ENVIRONMENT=dev

# Provider selection (Strategy/Factory). "mock" runs with no API key.
TUTOR_LLM_PROVIDER=mock
TUTOR_TTS_PROVIDER=mock
# Orchestration engine: langgraph (real agent graph) | mock (plain async fallback).
TUTOR_GENERATION_ENGINE=langgraph
# Persistence: memory | filesystem
TUTOR_STORAGE_BACKEND=memory

# --- Real Gemini generation (verified live 2026-06-25) ---
# Confirm ids with: python -m app.tools.list_models
# TUTOR_LLM_PROVIDER=gemini
# TUTOR_TTS_PROVIDER=gemini
# TUTOR_GEMINI_API_KEY=your-key-here
# gemini-2.5-flash is the GA default; if it returns sustained 503 "high demand",
# fall back to gemini-2.5-flash-lite (verified working) or gemini-3.5-flash.
# TUTOR_GEMINI_MODEL=gemini-2.5-flash
# TUTOR_GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
# TUTOR_GEMINI_VOICE=Kore
# TUTOR_STORAGE_BACKEND=filesystem
# TUTOR_DATA_DIR=./data
