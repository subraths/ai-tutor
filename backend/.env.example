# Copy to .env and adjust. All variables are prefixed with TUTOR_.
TUTOR_ENVIRONMENT=dev

# Provider selection (Strategy/Factory). Stay on "mock" until Phase 4.
TUTOR_LLM_PROVIDER=mock
TUTOR_TTS_PROVIDER=mock
TUTOR_GENERATION_ENGINE=mock

# Phase 4: switch providers to gemini and supply a VERIFIED model id + key.
# Model id is configuration, not code — confirm it against the live API.
# TUTOR_LLM_PROVIDER=gemini
# TUTOR_TTS_PROVIDER=gemini
# TUTOR_GEMINI_MODEL=gemini-flash-latest
# TUTOR_GEMINI_API_KEY=your-key-here
